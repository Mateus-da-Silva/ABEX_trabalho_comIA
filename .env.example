# ===========================
# AMBIENTE
# ===========================
NODE_ENV=development

# ===========================
# BANCO DE DADOS (MySQL)
# ===========================
DB_HOST=localhost
DB_PORT=3306
DB_USER=clinica_user
DB_PASSWORD=clinica_pass_2024
DB_NAME=clinica_saas
DB_ROOT_PASSWORD=root_clinica_2024

# ===========================
# REDIS (cache + filas)
# ===========================
REDIS_URL=redis://localhost:6379

# ===========================
# JWT
# ===========================
JWT_SECRET=troque_esta_chave_em_producao_use_256_bits
